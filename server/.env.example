# ── REQUIRED: Change this! Min 32 characters ────────────────────────────────
JWT_SECRET=befo-bakers-super-secret-jwt-key-2024-change-me

# ── Server port ──────────────────────────────────────────────────────────────
PORT=3000

# ── Database (sqlite = no setup needed) ─────────────────────────────────────
DB_TYPE=sqlite

# ── Admin login credentials ──────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=Admin123!

# ── Worker login credentials ─────────────────────────────────────────────────
WORKER_USER=baker1
WORKER_PASS=Baker123!
WORKER_NAME=Baker One

# ── Email (optional - OTP prints to console if not set) ─────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="BeFo Bakers" <noreply@befobakers.com>

# ── CORS allowed origins (comma-separated) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ── App URL for email links ──────────────────────────────────────────────────
APP_URL=http://localhost:3000